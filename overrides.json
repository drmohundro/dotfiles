{
  "skip_processing": [
    "README.md",
    "LICENSE",
    "AGENTS.md",
    "CLAUDE.md",
    "Makefile",
    "install.ps1",
    "overrides.json",
    "overrides.yaml",
    "tests",
    "zed"
  ],
  "macos": {
    "hammerspoon": "~/.hammerspoon",
    "karabiner.json": "~/.config/karabiner/karabiner.json",
    "config.fish": "~/.config/fish/config.fish",
    "nvim": ["~/.config/nvim"],
    "vimrc": ["~/.vimrc"],
    "vim": ["~/.vim"],
    "kitty": ["~/.config/kitty"],
    "starship.toml": ["~/.config/starship.toml"],
    "wezterm": ["~/.config/wezterm"],
    "ghostty": ["~/.config/ghostty"],
    "tmux": ["~/.config/tmux"],
    "zellij": ["~/.config/zellij"],
    "sketchybar": ["~/.config/sketchybar"],
    "borders": ["~/.config/borders"],
    "zed/settings.json": "~/.config/zed/settings.json",
    "zed/keymap.json": "~/.config/zed/keymap.json",
    "zed/tasks.json": "~/.config/zed/tasks.json"
  },
  "linux": {
    "config.fish": "~/.config/fish/config.fish",
    "nvim": ["~/.config/nvim"],
    "vimrc": ["~/.vimrc"],
    "vim": ["~/.vim"],
    "wezterm": ["~/.config/wezterm"]
  },
  "windows": {
    "vsvimrc": "~/.vsvimrc",
    "viemurc": "~/.viemurc",
    "nvim": ["%LOCALAPPDATA%/nvim"],
    "vimrc": ["~/.vimrc"],
    "vim": ["~/.vim"],
    "wezterm": ["~/.config/wezterm"],
    "zed/keymap.json": "%APPDATA%/zed/keymap.json",
    "zed/settings.json": "%APPDATA%/zed/settings.json",
    "zed/tasks.json": "%APPDATA%/zed/tasks.json"
  }
}
