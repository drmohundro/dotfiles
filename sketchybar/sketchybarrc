#!/bin/bash

source "$CONFIG_DIR/colors.sh"
PLUGIN_DIR="$CONFIG_DIR/plugins"

##### Bar #####
sketchybar --bar \
  position=top \
  height=36 \
  blur_radius=0 \
  color=$BASE \
  padding_left=12 \
  padding_right=12

##### Defaults #####
sketchybar --default \
  padding_left=4 \
  padding_right=4 \
  icon.font="Hack Nerd Font:Bold:15.0" \
  label.font="Hack Nerd Font:Bold:13.0" \
  icon.color=$TEXT \
  label.color=$TEXT \
  icon.padding_left=6 \
  icon.padding_right=4 \
  label.padding_left=4 \
  label.padding_right=6 \
  background.color=$SURFACE0 \
  background.corner_radius=8 \
  background.height=26 \
  background.drawing=off

##### FlashSpace Workspaces #####
sketchybar --add event flashspace_workspace_change

declare -A SPACE_ICONS=(
  [1]="1 ¾░ÿÉ"  # coding
  [2]="2 ¾░ûƒ"  # browser
  [3]="3 ¾░Æ▒"  # slack
  [4]="4 ¾░ç«"  # email
  [5]="5 ¾░ØÜ"  # music
  [6]="6 ¾░áª"  # misc
  [7]="7 ¾░èû"  # gaming
)

WORKSPACE_NAMES=(coding browser slack email music misc gaming)

for i in 1 2 3 4 5 6 7; do
  WS_NAME="${WORKSPACE_NAMES[$((i-1))]}"
  # To use AeroSpace: swap script to aerospace.sh, click_script to "aerospace workspace $i",
  # and event to aerospace_workspace_change
  sketchybar --add item space.$i left \
    --set space.$i \
      icon="${SPACE_ICONS[$i]}" \
      icon.padding_left=8 \
      icon.padding_right=8 \
      label.drawing=off \
      background.drawing=on \
      background.color=$SURFACE0 \
      background.corner_radius=6 \
      background.height=24 \
      script="$PLUGIN_DIR/flashspace.sh" \
      click_script="flashspace workspace $WS_NAME" \
    --subscribe space.$i flashspace_workspace_change front_app_switched
done


##### Clock (Right, far right) #####
sketchybar --add item clock right \
  --set clock \
  update_freq=20 \
  icon=¾░Ñö \
  icon.color=$BLUE \
  background.drawing=on \
  script="$PLUGIN_DIR/clock.sh"

##### WiFi ÔÇö full (icon + IP, external monitor) #####
sketchybar --add item wifi right \
  --set wifi \
  update_freq=10 \
  background.drawing=on \
  script="$PLUGIN_DIR/wifi.sh"

##### WiFi ÔÇö icon only (laptop condensed view) #####
sketchybar --add item wifi_icon right \
  --set wifi_icon \
  update_freq=10 \
  background.drawing=on \
  script="$PLUGIN_DIR/wifi.sh"

##### Battery (Right) #####
sketchybar --add item battery right \
  --set battery \
  update_freq=120 \
  background.drawing=on \
  script="$PLUGIN_DIR/battery.sh" \
  --subscribe battery system_woke power_source_change

##### Volume (Right) #####
sketchybar --add item volume right \
  --set volume \
  icon.color=$YELLOW \
  background.drawing=on \
  script="$PLUGIN_DIR/volume.sh" \
  --subscribe volume volume_change

##### Memory (Right) #####
sketchybar --add item memory right \
  --set memory \
  update_freq=30 \
  icon=¾░ìø \
  icon.color=$MAUVE \
  background.drawing=on \
  script="$PLUGIN_DIR/memory.sh"

##### CPU (Right) #####
sketchybar --add item cpu right \
  --set cpu \
  update_freq=5 \
  icon=¾░ÿÜ \
  icon.color=$BLUE \
  background.drawing=on \
  script="$PLUGIN_DIR/cpu.sh"

##### Media (Right) #####
sketchybar --add item media right \
  --set media \
  update_freq=5 \
  icon=¾░ØÜ \
  icon.color=$GREEN \
  label.color=$GREEN \
  drawing=off \
  background.drawing=on \
  script="$PLUGIN_DIR/media.sh"

##### Calendar (Right) #####
sketchybar --add item calendar right \
  --set calendar \
  update_freq=60 \
  icon=¾░â¡ \
  icon.color=$PEACH \
  label.color=$PEACH \
  drawing=off \
  background.drawing=on \
  script="$PLUGIN_DIR/calendar.sh"

##### Display setup ÔÇö runs on start and when displays change #####
sketchybar --add item display_setup left \
  --set display_setup \
  drawing=off \
  script="$PLUGIN_DIR/display_setup.sh" \
  --subscribe display_setup display_change system_woke

sketchybar --update

# Run display setup immediately on load
"$PLUGIN_DIR/display_setup.sh"

# Highlight the currently focused FlashSpace workspace
FOCUSED=$(flashspace get-workspace 2>/dev/null)
[[ -n "$FOCUSED" ]] && sketchybar --trigger flashspace_workspace_change WORKSPACE="$FOCUSED"
