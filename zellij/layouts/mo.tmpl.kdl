layout {
  default_tab_template {
    pane size=2 borderless=true {
      plugin location="file:~/.config/zellij/plugins/zjstatus.wasm" {
        format_left   "{mode}#[bg=#${base00}] {tabs}"
        format_center ""
        format_right  "{command_context_pills}#[bg=#${base00},fg=#${base09}]#[bg=#${base09},fg=#${base01},bold]  {session} #[bg=#${base00},fg=#${base09}]"
        format_space  ""
        format_hide_on_overlength "true"
        format_precedence "crl"

        border_enabled  "false"
        border_char     "─"
        border_format   "#[fg=#${border}]{char}"
        border_position "top"

        mode_normal        "#[bg=#${base0B},fg=#${base02},bold] NORMAL#[bg=#${base03},fg=#${base0B}]█"
        mode_locked        "#[bg=#${base04},fg=#${base02},bold] LOCKED #[bg=#${base03},fg=#${base04}]█"
        mode_resize        "#[bg=#${base08},fg=#${base02},bold] RESIZE#[bg=#${base03},fg=#${base08}]█"
        mode_pane          "#[bg=#${base0D},fg=#${base02},bold] PANE#[bg=#${base03},fg=#${base0D}]█"
        mode_tab           "#[bg=#${base07},fg=#${base02},bold] TAB#[bg=#${base03},fg=#${base07}]█"
        mode_scroll        "#[bg=#${base0A},fg=#${base02},bold] SCROLL#[bg=#${base03},fg=#${base0A}]█"
        mode_enter_search  "#[bg=#${base0D},fg=#${base02},bold] ENT-SEARCH#[bg=#${base03},fg=#${base0D}]█"
        mode_search        "#[bg=#${base0D},fg=#${base02},bold] SEARCH#[bg=#${base03},fg=#${base0D}]█"
        mode_rename_tab    "#[bg=#${base07},fg=#${base02},bold] RENAME-TAB#[bg=#${base03},fg=#${base07}]█"
        mode_rename_pane   "#[bg=#${base0D},fg=#${base02},bold] RENAME-PANE#[bg=#${base03},fg=#${base0D}]█"
        mode_session       "#[bg=#${base0E},fg=#${base02},bold] SESSION#[bg=#${base03},fg=#${base0E}]█"
        mode_move          "#[bg=#${base0F},fg=#${base02},bold] MOVE#[bg=#${base03},fg=#${base0F}]█"
        mode_prompt        "#[bg=#${base0D},fg=#${base02},bold] PROMPT#[bg=#${base03},fg=#${base0D}]█"
        mode_tmux          "#[bg=#${base09},fg=#${base02},bold] TMUX#[bg=#${base03},fg=#${base09}]█"

        tab_normal              "#[bg=#${base03},fg=#${base0D}]█#[bg=#${base0D},fg=#${base02},bold]{index} #[bg=#${base02},fg=#${base05},bold] {name}{floating_indicator}#[bg=#${base03},fg=#${base02},bold]█"
        tab_normal_fullscreen   "#[bg=#${base03},fg=#${base0D}]█#[bg=#${base0D},fg=#${base02},bold]{index} #[bg=#${base02},fg=#${base05},bold] {name}{fullscreen_indicator}#[bg=#${base03},fg=#${base02},bold]█"
        tab_normal_sync         "#[bg=#${base03},fg=#${base0D}]█#[bg=#${base0D},fg=#${base02},bold]{index} #[bg=#${base02},fg=#${base05},bold] {name}{sync_indicator}#[bg=#${base03},fg=#${base02},bold]█"

        tab_active              "#[bg=#${base03},fg=#${base09}]█#[bg=#${base09},fg=#${base02},bold]{index} #[bg=#${base02},fg=#${base05},bold] {name}{floating_indicator}#[bg=#${base03},fg=#${base02},bold]█"
        tab_active_fullscreen   "#[bg=#${base03},fg=#${base09}]█#[bg=#${base09},fg=#${base02},bold]{index} #[bg=#${base02},fg=#${base05},bold] {name}{fullscreen_indicator}#[bg=#${base03},fg=#${base02},bold]█"
        tab_active_sync         "#[bg=#${base03},fg=#${base09}]█#[bg=#${base09},fg=#${base02},bold]{index} #[bg=#${base02},fg=#${base05},bold] {name}{sync_indicator}#[bg=#${base03},fg=#${base02},bold]█"

        tab_separator           "#[bg=#${base00}] "

        tab_sync_indicator       " "
        tab_fullscreen_indicator " 󰊓"
        tab_floating_indicator   " 󰹙"

        command_context_pills_command             "/usr/bin/env python3 ${home}/.config/zellij/helpers/statusline-context.py"
        command_context_pills_format              "{stdout} "
        command_context_pills_interval            "10"
        command_context_pills_rendermode          "dynamic"
        command_context_pills_hideonemptystdout   "true"

      }
    }

    children

    pane size=1 borderless=true {
      plugin location="file:~/.config/zellij/plugins/zjstatus.wasm" {
        format_left   "{mode}"
        format_center ""
        format_right  "{datetime}"
        format_space  ""
        format_hide_on_overlength "true"
        format_precedence "lcr"

        border_enabled  "false"
        border_char     "─"
        border_format   "#[fg=#${border}]{char}"
        border_position "top"

        mode_locked        "#[bg=#${base04},fg=#${base02},bold] LOCKED #[bg=#${base00},fg=#${base05}] Ctrl g normal | Alt t tab | Alt d split → | Alt ⇧d split ↓ | Alt hjkl focus | Alt w close "
        mode_normal        "#[bg=#${base0B},fg=#${base02},bold] NORMAL #[bg=#${base00},fg=#${base05}] Ctrl g lock | Ctrl p pane | Ctrl t tab | Ctrl n resize | Ctrl s scroll | Ctrl o session | Ctrl b tmux | Ctrl q quit "
        mode_pane          "#[bg=#${base0D},fg=#${base02},bold] PANE #[bg=#${base00},fg=#${base05}] hjkl focus | r split → | d split ↓ | n new | f fullscreen | x close | c rename | Esc normal "
        mode_tab           "#[bg=#${base07},fg=#${base02},bold] TAB #[bg=#${base00},fg=#${base05}] hjkl prev/next | n new | x close | r rename | 1-9 goto | s sync | Esc normal "
        mode_resize        "#[bg=#${base08},fg=#${base02},bold] RESIZE #[bg=#${base00},fg=#${base05}] hjkl resize | +/- resize | Ctrl n normal | Esc normal "
        mode_scroll        "#[bg=#${base0A},fg=#${base02},bold] SCROLL #[bg=#${base00},fg=#${base05}] jk scroll | ud half-page | Ctrl f/b page | s search | e edit | Esc normal "
        mode_enter_search  "#[bg=#${base0D},fg=#${base02},bold] SEARCH #[bg=#${base00},fg=#${base05}] type query | Enter search | Esc scroll | Ctrl c scroll "
        mode_search        "#[bg=#${base0D},fg=#${base02},bold] SEARCH #[bg=#${base00},fg=#${base05}] n next | p previous | c case | w wrap | o whole-word | Esc normal "
        mode_rename_tab    "#[bg=#${base07},fg=#${base02},bold] RENAME-TAB #[bg=#${base00},fg=#${base05}] type name | Enter accept | Esc cancel | Ctrl c normal "
        mode_rename_pane   "#[bg=#${base0D},fg=#${base02},bold] RENAME-PANE #[bg=#${base00},fg=#${base05}] type name | Enter accept | Esc cancel | Ctrl c normal "
        mode_session       "#[bg=#${base0E},fg=#${base02},bold] SESSION #[bg=#${base00},fg=#${base05}] w sessions | p plugins | c config | l layouts | a about | d detach | Esc normal "
        mode_move          "#[bg=#${base0F},fg=#${base02},bold] MOVE #[bg=#${base00},fg=#${base05}] hjkl move pane | n move | p move back | w floating | s stacked | Tab move | Esc normal "
        mode_prompt        "#[bg=#${base0D},fg=#${base02},bold] PROMPT #[bg=#${base00},fg=#${base05}] Enter accept | Esc cancel "
        mode_tmux          "#[bg=#${base09},fg=#${base02},bold] TMUX #[bg=#${base00},fg=#${base05}] c tab | % split → | \" split ↓ | hjkl focus | [ scroll | d detach | Ctrl b send prefix "

        datetime          "#[fg=#${border},bold] {format} "
        datetime_format   "%A, %d %b %Y %H:%M"
        datetime_timezone "America/Chicago"
      }
    }
  }

  tab {
    pane
  }
}
